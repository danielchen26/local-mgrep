[project]
name = "local-mgrep"
version = "0.1.0"
description = "Free local semantic code search using Ollama"
requires-python = ">=3.9"
dependencies = [
    "click>=8.0",
    "requests>=2.31",
    "numpy>=1.26",
    "scikit-learn>=1.4",
    "tree-sitter>=0.21",
    "tree-sitter-languages>=1.10",
]

[project.scripts]
mgrep = "local_mgrep.src.cli:main"

[tool.setuptools.packages.find]
where = ["."]
include = ["local_mgrep*"]